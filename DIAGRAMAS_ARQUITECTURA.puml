@startuml Arquitectura_General
!define AWSPUML https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v14.0/dist
!include AWSPUML/AWSCommon
!include AWSPUML/Compute/MobileApplication
!include AWSPUML/ManagementAndGovernance/CloudFormation

title Arquitectura General - KAIZEN TFG

package "Cliente (Dispositivo Android)" {
    MobileApplication(flutter, "Flutter App", "Versión 3.35.7") {
        [LoginScreen]
        [HomeScreen]
        [Features]
    }
}

package "Servicios (Local)" {
    [AuthService]
    [AppTheme]
    [GoRouter]
}

package "Firebase (Google Cloud)" {
    [Firebase Core]
    [Firebase Auth]
    [Google Sign-In]
    [Cloud Firestore]
    [Firebase Analytics]
}

package "Datos (Cloud)" {
    database "Firestore DB" {
        [users]
        [products]
        [progress]
    }
}

LoginScreen --> AuthService : signInWithGoogle()
HomeScreen --> AuthService : currentUser
Features --> Firestore

AuthService --> Firebase Core
Firebase Core --> Firebase Auth
Firebase Auth --> Google Sign-In
Firebase Auth --> Cloud Firestore

Cloud Firestore --> Firestore DB

@enduml

---

@startuml Flujo_Autenticacion
title Flujo de Autenticación - Google Sign-In

actor Usuario
participant "LoginScreen" as LS
participant "AuthService" as AS
participant "FirebaseAuth" as FA
participant "GoogleSignIn" as GS
participant "Firestore" as FS

Usuario -> LS: Toca "Iniciar con Google"
LS -> AS: signInWithGoogle()
AS -> GS: googleUser = await signIn()
GS --> AS: GoogleSignInAccount
AS -> FA: credential = GoogleAuthProvider.credential()
FA -> FA: signInWithCredential(credential)
FA --> AS: UserCredential (user)
AS -> FS: users.doc(uid).set(userData)
FS --> AS: OK

AS --> LS: User object
LS -> LS: setState() -> mostrar SnackBar
LS -> Usuario: "¡Bienvenido, Adrian!"
LS -> LS: context.go('/') -> HomeScreen
LS --> Usuario: Navega a HomeScreen

@enduml

---

@startuml Estructura_Carpetas
title Estructura de Proyecto Flutter

package "kaizen_app/" {
    package "lib/" {
        file "main.dart" {
            note "Entry point\nInitialize Firebase\nSetup GoRouter"
        }

        file "firebase_options.dart" {
            note "Configuración\nde Firebase"
        }

        package "core/" {
            package "services/" {
                file "auth_service.dart" {
                    note "Static methods:\n- signInWithGoogle()\n- signOut()\n- currentUser"
                }
            }

            package "theme/" {
                file "app_theme.dart" {
                    note "Material Design 3\nTema oscuro\nColores personalizados"
                }
            }
        }

        package "features/" {
            package "auth/" {
                package "screens/" {
                    file "login_screen.dart" {
                        note "Google Sign-In button\nError handling\nLoading state"
                    }
                }
            }

            package "home/" {
                package "screens/" {
                    file "home_screen.dart" {
                        note "User info display\nLogout button\nNavigation"
                    }
                }
            }
        }
    }

    package "android/" {
        package "app/" {
            file "google-services.json" {
                note "Firebase config\nAndroid SHA-1\nAPI keys"
            }

            file "build.gradle" {
                note "Google Services plugin\nFirebase BoM\nDependencies"
            }
        }
    }

    file "pubspec.yaml" {
        note "Flutter dependencies\nAndroid version info"
    }
}

@enduml

---

@startuml Flujo_Datos_Firestore
title Flujo de Datos - Firestore

package "Firebase" {
    cloud "Cloud Firestore" {
        package "Database: kaizen-tfg-real" {
            collection "(default)" {
                subcollection "users" {
                    document "uid_usuario_1" {
                        field "uid: String"
                        field "name: String"
                        field "email: String"
                        field "photoUrl: String"
                        field "createdAt: Timestamp"
                    }

                    document "uid_usuario_2" {
                        field "uid: String"
                        field "name: String"
                        field "email: String"
                        field "photoUrl: String"
                        field "createdAt: Timestamp"
                    }
                }

                subcollection "products" {
                    document "product_1" {
                        field "id: String"
                        field "name: String"
                        field "quantity: Number"
                        field "price: Number"
                    }
                }

                subcollection "progress" {
                    document "progress_1" {
                        field "userId: String"
                        field "month: String"
                        field "improvements: Number"
                        field "rating: Number"
                    }
                }
            }
        }
    }
}

@enduml

---

@startuml Estados_Navegacion
title Estados y Navegación con GoRouter

state "Inicio" as Init
state "LoginScreen" as Login
state "Google Auth" as GoogleAuth
state "HomeScreen" as Home
state "Logout" as LogOut

Init --> Login: app start
Login --> GoogleAuth: user taps\n"Iniciar con Google"
GoogleAuth --> Home: auth success\nuser saved
GoogleAuth --> Login: auth fail\nshow error
Home --> LogOut: user taps\n"Cerrar sesión"
LogOut --> Login: redirect

@enduml

---

@startuml Ciclo_Vida_App
title Ciclo de Vida - Aplicación KAIZEN

participant "App Startup" as app
participant "Firebase Init" as fb
participant "GoRouter" as router
participant "AuthService" as auth
participant "UI Render" as ui

app -> fb: Firebase.initializeApp()
fb -> fb: Load google-services.json
fb -> fb: Initialize Auth & Firestore
fb --> app: ✓ Firebase ready

app -> router: Setup GoRouter
router -> router: Define routes
router -> app: ✓ Router ready

app -> auth: Check currentUser
auth -> fb: FirebaseAuth.instance.currentUser
fb --> auth: User? (null or User)
auth --> app: ✓ Auth state known

app -> ui: Render MaterialApp
alt User logged in
    ui -> ui: Show HomeScreen
else User not logged in
    ui -> ui: Show LoginScreen
end

ui --> app: ✓ App ready

note right of app
    App ahora está lista para:
    - Manejo de rutas
    - Cambios en auth state
    - Interacción del usuario
end note

@enduml
